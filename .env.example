# Azure OpenAI (필수)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://skax.ai-talentlab.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
OPENAI_MODEL=gpt-5.4
EMBEDDING_MODEL=text-embedding-3-large

# 공공데이터포털 API (필수)
PUBLIC_DATA_API_KEY=your_public_data_api_key

# Qdrant 설정
# QDRANT_URL 없으면 로컬(./qdrant_db/), 있으면 클라우드 자동 전환
QDRANT_DB_PATH=./qdrant_db
QDRANT_URL=https://a891204a-f7dc-4b96-a990-7c4683f0e1f8.us-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=power_market_rules
VECTOR_SIZE=3072

# 경로
PDF_PATH=./data/pdf

# 앱 설정
MAX_CONVERSATION_TURNS=5
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=0.7

# LangSmith 모니터링 (선택 — 필요 시 주석 해제)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=power-market-ai
